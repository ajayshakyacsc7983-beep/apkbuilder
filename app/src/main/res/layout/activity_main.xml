<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_height"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_dark_purple">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Title Header -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIC TAC TOE"
            android:textColor="@color/text_white"
            android:textSize="32sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.15"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modern Dark Edition"
            android:textColor="@color/accent_neon"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toBottomOf="@+id/titleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Game Mode Selector -->
        <LinearLayout
            android:id="@+id/modeContainer"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:background="@drawable/mode_switch_bg"
            android:layout_marginTop="24dp"
            android:padding="4dp"
            app:layout_constraintTop_toBottomOf="@+id/subtitleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btnVsAI"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="vs AI Bot"
                android:textAllCaps="false"
                android:textColor="@color/text_white"
                android:fontFamily="sans-serif-bold"
                android:background="@drawable/button_accent_bg"
                android:elevation="4dp" />

            <Button
                android:id="@+id/btnVsFriend"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="vs Friend"
                android:textAllCaps="false"
                android:textColor="@color/text_muted"
                android:fontFamily="sans-serif-bold"
                android:background="#00000000"
                android:elevation="0dp" />
        </LinearLayout>

        <!-- Scoreboard Card -->
        <LinearLayout
            android:id="@+id/scoreboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@+id/modeContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Player X Score -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Player X"
                    android:textColor="@color/color_x"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold" />
                <TextView
                    android:id="@+id/tvScoreX"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_white"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/grid_line"
                android:layout_marginHorizontal="10dp" />

            <!-- Ties Score -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ties"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold" />
                <TextView
                    android:id="@+id/tvScoreTies"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_white"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/grid_line"
                android:layout_marginHorizontal="10dp" />

            <!-- Player O Score -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvLabelO"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Bot (O)"
                    android:textColor="@color/color_o"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold" />
                <TextView
                    android:id="@+id/tvScoreO"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_white"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Status Banner -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your turn! Tap a cell to play"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@+id/scoreboard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 3x3 Grid Board -->
        <GridLayout
            android:id="@+id/boardGrid"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:columnCount="3"
            android:rowCount="3"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@+id/tvStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Row 1 -->
            <Button
                android:id="@+id/btn0"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/grid_button_bg"
                android:textSize="36sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_white" />

            <Button
                android:id="@+id/btn1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/grid_button_bg"
                android:textSize="36sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_white" />

            <Button
                android:id="@+id/btn2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/grid_button_bg"
                android:textSize="36sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_white" />

            <!-- Row 2 -->
            <Button
                android:id="@+id/btn3"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/grid_button_bg"
                android:textSize="36sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_white" />

            <Button
                android:id="@+id/btn4"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/grid_button_bg"
                android:textSize="36sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_white" />

            <Button
                android:id="@+id/btn5"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/grid_button_bg"
                android:textSize="36sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_white" />

            <!-- Row 3 -->
            <Button
                android:id="@+id/btn6"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/grid_button_bg"
                android:textSize="36sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_white" />

            <Button
                android:id="@+id/btn7"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/grid_button_bg"
                android:textSize="36sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_white" />

            <Button
                android:id="@+id/btn8"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/grid_button_bg"
                android:textSize="36sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_white" />
        </GridLayout>

        <!-- Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@+id/boardGrid"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btnResetBoard"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1.2"
                android:layout_marginEnd="8dp"
                android:text="Play Again"
                android:textColor="@color/text_white"
                android:textSize="16sp"
                android:fontFamily="sans-serif-bold"
                android:background="@drawable/button_accent_bg"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnResetScores"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="0.8"
                android:layout_marginStart="8dp"
                android:text="Reset Score"
                android:textColor="@color/primary_light"
                android:textSize="14sp"
                android:fontFamily="sans-serif-bold"
                android:background="@drawable/button_outline_bg"
                android:textAllCaps="false" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>